<!doctype html>
<html lang="${LANG_HTML}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>${SITE_TITLE} ${BROWSER_TITLE_SUFFIX}</title>
  <style>
    ${SHARED_STYLES}
  </style>
  <style>
    .hero::after {
      content: "TFW";
      position: absolute;
      right: 28px;
      bottom: -24px;
      font: 800 clamp(70px, 16vw, 190px) / 1 var(--font-ui);
      letter-spacing: -0.08em;
      color: rgba(245, 218, 174, 0.045);
      pointer-events: none;
    }

    a.action-link,
    button.action-link {
      appearance: none;
      border: 1px solid var(--line);
      border-radius: 999px;
      font: 700 14px / 1 var(--font-ui);
      letter-spacing: 0.02em;
      text-decoration: none;
      padding: 12px 18px;
      color: var(--text);
      background: rgba(255, 255, 255, 0.055);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, box-shadow 160ms ease;
      cursor: pointer;
    }

    a.action-link:hover,
    button.action-link:hover {
      transform: translateY(-2px);
      border-color: var(--line-strong);
      background: rgba(255, 255, 255, 0.09);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .toolbar {
      display: grid;
      gap: 18px;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
      margin-bottom: 22px;
    }

    .stats {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
    }

    .chip {
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.055);
      padding: 11px 15px;
      color: var(--muted);
      font: 700 13px / 1 var(--font-ui);
      white-space: nowrap;
    }

    .manager {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: center;
      margin-bottom: 22px;
      padding: 18px 20px;
      border: 1px solid rgba(127, 205, 162, 0.28);
      border-radius: 24px;
      background:
        linear-gradient(135deg, rgba(127, 205, 162, 0.13), transparent),
        rgba(255, 255, 255, 0.045);
    }

    .manager strong {
      display: block;
      margin-bottom: 5px;
      color: var(--text);
      font-size: 18px;
    }

    .manager p {
      font-size: 14px;
    }

    .manager-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
      flex: 0 0 auto;
    }

    .list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 14px;
    }

    .item {
      position: relative;
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 20px;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.075), transparent 58%),
        rgba(255, 255, 255, 0.045);
      display: grid;
      gap: 14px;
      overflow: hidden;
      animation: rise 260ms ease both;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    }

    .item::before {
      content: "";
      position: absolute;
      inset: 0 auto 0 0;
      width: 4px;
      background: linear-gradient(var(--accent-strong), rgba(127, 205, 162, 0.55));
      opacity: 0.78;
    }

    .item:hover {
      transform: translateY(-2px);
      border-color: var(--line-strong);
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.105), transparent 58%),
        rgba(255, 255, 255, 0.06);
    }

    .item-head {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: start;
    }

    .title-wrap {
      min-width: 0;
      padding-left: 6px;
    }

    .type {
      display: inline-flex;
      align-items: center;
      padding: 6px 10px;
      border: 1px solid rgba(226, 155, 69, 0.22);
      border-radius: 999px;
      font: 800 11px / 1 var(--font-ui);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent-strong);
      background: var(--accent-soft);
      margin-bottom: 11px;
    }

    .type.dir {
      color: var(--green);
      border-color: rgba(127, 205, 162, 0.22);
      background: var(--green-soft);
    }

    .name {
      margin: 0 0 8px;
      font-size: clamp(20px, 3vw, 28px);
      line-height: 1.18;
      letter-spacing: -0.03em;
      word-break: break-all;
    }

    .name a {
      color: inherit;
      text-decoration: none;
    }

    .name a:hover {
      color: var(--accent-strong);
      text-decoration: underline;
      text-decoration-thickness: 2px;
      text-underline-offset: 5px;
    }

    .meta {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      color: var(--muted);
      font: 14px / 1.4 var(--font-ui);
    }

    .dot {
      width: 5px;
      height: 5px;
      border-radius: 999px;
      background: rgba(185, 170, 146, 0.42);
    }

    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
      align-items: center;
    }

    .action-link.primary {
      color: #21170b;
      border-color: transparent;
      background: linear-gradient(135deg, var(--accent-strong), #e58c32);
      box-shadow: 0 14px 34px rgba(226, 155, 69, 0.24);
    }

    .action-link.danger {
      color: #ffd6d1;
      border-color: rgba(255, 125, 110, 0.3);
      background: var(--danger-soft);
    }

    .action-link[disabled] {
      cursor: not-allowed;
      opacity: 0.58;
      transform: none;
    }

    .state {
      padding: 30px 22px;
      border-radius: 24px;
      border: 1px dashed var(--line-strong);
      background: rgba(255, 255, 255, 0.04);
      color: var(--muted);
      text-align: center;
      font-size: 17px;
    }

    @media (max-width: 820px) {
      .toolbar {
        grid-template-columns: 1fr;
      }

      .stats {
        justify-content: flex-start;
      }

      .item-head {
        flex-direction: column;
      }

      .actions {
        justify-content: flex-start;
      }

      .manager {
        align-items: flex-start;
        flex-direction: column;
      }

      .manager-actions {
        justify-content: flex-start;
      }
    }
  </style>
</head>
<body>
  <main>
    <section class="hero">
      <div class="eyebrow" id="eyebrow">${BROWSER_EYEBROW_ROOT}</div>
      <h1 id="title">${BROWSER_MAIN_TITLE}</h1>
      <p id="subtitle">${BROWSER_LOADING}</p>
      <div class="nav">
        <a class="nav-link" href="/">${NAV_ROOT}</a>
        <a class="nav-link" href="/uploads/">${NAV_UPLOADS}</a>
        <a class="nav-link" href="/upload">${NAV_UPLOAD}</a>
        <a class="nav-link" href="${PROJECT_URL}" target="_blank" rel="noopener noreferrer">${NAV_PROJECT}</a>
        <a class="nav-link" id="parent-link" href="/" hidden>${NAV_PARENT}</a>
      </div>
    </section>
    <section class="panel">
      <div class="toolbar">
        <div class="field">
          <label for="filter">${FILTER_LABEL}</label>
          <input id="filter" type="search" placeholder="${FILTER_PLACEHOLDER}">
        </div>
        <div class="stats">
          <div class="chip" id="count-chip">0 ${COUNT_SUFFIX}</div>
          <div class="chip" id="path-chip">/</div>
        </div>
      </div>
      <div class="manager" id="manager-panel" hidden>
        <div>
          <strong id="manager-title"></strong>
          <p id="manager-text"></p>
        </div>
        <div class="manager-actions">
          <a class="action-link primary" id="manager-login" href="/upload?next=/uploads/">${MANAGE_LOGIN}</a>
          <button class="action-link" id="manager-logout" type="button" hidden>${MANAGE_LOGOUT}</button>
        </div>
      </div>
      <div class="state" id="state">${BROWSER_LOADING}</div>
      <ul class="list" id="list" hidden></ul>
    </section>
  </main>

  <script>
    const I18N = {
      unknownSize: ${JS_UNKNOWN_SIZE},
      unknownTime: ${JS_UNKNOWN_TIME},
      eyebrowRoot: ${JS_EYEBROW_ROOT},
      eyebrowChild: ${JS_EYEBROW_CHILD},
      titleRoot: ${JS_TITLE_ROOT},
      titlePrefix: ${JS_TITLE_PREFIX},
      subtitle: ${JS_SUBTITLE},
      stateLoading: ${JS_STATE_LOADING},
      stateNoMatch: ${JS_STATE_NO_MATCH},
      stateEmpty: ${JS_STATE_EMPTY},
      stateLoadFail: ${JS_STATE_LOAD_FAIL},
      itemCountSuffix: ${JS_ITEM_COUNT_SUFFIX},
      typeDir: "DIR",
      typeFile: "FILE",
      labelDir: ${JS_LABEL_DIR},
      labelEnter: ${JS_LABEL_ENTER},
      labelOpen: ${JS_LABEL_OPEN},
      labelCopy: ${JS_LABEL_COPY},
      labelCopied: ${JS_LABEL_COPIED},
      labelCopyFail: ${JS_LABEL_COPY_FAIL},
      labelDownload: ${JS_LABEL_DOWNLOAD},
      labelDelete: ${JS_LABEL_DELETE},
      labelDeleting: ${JS_LABEL_DELETING},
      labelDeleted: ${JS_LABEL_DELETED},
      labelDeleteFailed: ${JS_LABEL_DELETE_FAILED},
      labelDeleteConfirm: ${JS_LABEL_DELETE_CONFIRM},
      manageReadyTitle: ${JS_MANAGE_READY_TITLE},
      manageReadyText: ${JS_MANAGE_READY_TEXT},
      manageLockedTitle: ${JS_MANAGE_LOCKED_TITLE},
      manageLockedText: ${JS_MANAGE_LOCKED_TEXT}
    };

    const siteTitle = ${JS_SITE_TITLE};
    const titleSuffix = ${JS_TITLE_SUFFIX};
    const localeTag = ${JS_LOCALE};

    const title = document.getElementById("title");
    const subtitle = document.getElementById("subtitle");
    const eyebrow = document.getElementById("eyebrow");
    const filterInput = document.getElementById("filter");
    const countChip = document.getElementById("count-chip");
    const pathChip = document.getElementById("path-chip");
    const parentLink = document.getElementById("parent-link");
    const managerPanel = document.getElementById("manager-panel");
    const managerTitle = document.getElementById("manager-title");
    const managerText = document.getElementById("manager-text");
    const managerLogin = document.getElementById("manager-login");
    const managerLogout = document.getElementById("manager-logout");
    const state = document.getElementById("state");
    const list = document.getElementById("list");

    const currentPath = location.pathname.endsWith("/") ? location.pathname : `${location.pathname}/`;
    const dataUrl = `/_listing${currentPath}`;
    const isUploadRoot = currentPath === "/uploads/";
    let canDeleteItems = false;
    let items = [];

    function formatBytes(bytes) {
      if (typeof bytes !== "number" || Number.isNaN(bytes)) {
        return I18N.unknownSize;
      }

      const units = ["B", "KB", "MB", "GB", "TB"];
      let value = bytes;
      let index = 0;

      while (value >= 1024 && index < units.length - 1) {
        value /= 1024;
        index += 1;
      }

      return `${value.toFixed(value >= 100 || index === 0 ? 0 : 1)} ${units[index]}`;
    }

    function formatTime(value) {
      if (!value) {
        return I18N.unknownTime;
      }

      const date = new Date(value);
      if (Number.isNaN(date.getTime())) {
        return String(value);
      }

      return new Intl.DateTimeFormat(localeTag, {
        dateStyle: "medium",
        timeStyle: "short"
      }).format(date);
    }

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll("\"", "&quot;")
        .replaceAll("'", "&#39;");
    }

    function joinPath(basePath, name, isDirectory) {
      const cleanBase = basePath.endsWith("/") ? basePath : `${basePath}/`;
      const encoded = encodeURIComponent(name).replaceAll("%2F", "/");
      return `${cleanBase}${encoded}${isDirectory ? "/" : ""}`;
    }

    function updateHeader() {
      const label = currentPath === "/" ? "/" : currentPath;
      eyebrow.textContent = currentPath === "/" ? I18N.eyebrowRoot : I18N.eyebrowChild;
      title.textContent = currentPath === "/" ? I18N.titleRoot : `${I18N.titlePrefix} ${currentPath}`;
      subtitle.textContent = I18N.subtitle;
      pathChip.textContent = label;
      document.title = `${label} | ${siteTitle} ${titleSuffix}`;

      if (currentPath === "/") {
        parentLink.hidden = true;
        parentLink.href = "/";
      } else {
        const trimmed = currentPath.endsWith("/") ? currentPath.slice(0, -1) : currentPath;
        const lastSlashIndex = trimmed.lastIndexOf("/");
        const parentPath = lastSlashIndex <= 0 ? "/" : `${trimmed.slice(0, lastSlashIndex)}/`;
        parentLink.hidden = false;
        parentLink.href = parentPath;
      }
    }

    function setState(message) {
      state.hidden = false;
      state.textContent = message;
      list.hidden = true;
    }

    function updateManagerPanel() {
      if (!isUploadRoot) {
        managerPanel.hidden = true;
        return;
      }

      managerPanel.hidden = false;
      managerTitle.textContent = canDeleteItems ? I18N.manageReadyTitle : I18N.manageLockedTitle;
      managerText.textContent = canDeleteItems ? I18N.manageReadyText : I18N.manageLockedText;
      managerLogin.hidden = canDeleteItems;
      managerLogout.hidden = !canDeleteItems;
    }

    function renderList() {
      const keyword = filterInput.value.trim().toLowerCase();
      const filtered = items.filter((item) => item.name.toLowerCase().includes(keyword));
      countChip.textContent = `${filtered.length} ${I18N.itemCountSuffix}`;

      if (filtered.length === 0) {
        setState(keyword ? I18N.stateNoMatch : I18N.stateEmpty);
        return;
      }

      state.hidden = true;
      list.hidden = false;
      list.innerHTML = filtered.map((item, index) => {
        const isDirectory = item.type === "directory";
        const href = joinPath(currentPath, item.name, isDirectory);
        const primaryLabel = isDirectory ? I18N.labelEnter : I18N.labelOpen;
        const secondaryLabel = isDirectory ? I18N.labelCopy : I18N.labelDownload;
        const secondaryAttrs = isDirectory
          ? `data-copy="${escapeHtml(location.origin + href)}"`
          : `href="${escapeHtml(href)}" download`;
        const deleteAction = canDeleteItems && !isDirectory
          ? `<button class="action-link danger" type="button" data-delete-name="${escapeHtml(item.name)}" data-delete-href="${escapeHtml(href)}">${I18N.labelDelete}</button>`
          : "";
        const sizeText = isDirectory ? I18N.labelDir : formatBytes(item.size);
        const timeText = formatTime(item.mtime);

        return `
          <li class="item" style="animation-delay:${index * 28}ms">
            <div class="item-head">
              <div class="title-wrap">
                <div class="type ${isDirectory ? "dir" : "file"}">${isDirectory ? I18N.typeDir : I18N.typeFile}</div>
                <h2 class="name"><a href="${escapeHtml(href)}">${escapeHtml(item.name)}${isDirectory ? "/" : ""}</a></h2>
                <div class="meta">
                  <span>${sizeText}</span>
                  <span class="dot"></span>
                  <span>${timeText}</span>
                </div>
              </div>
              <div class="actions">
                <a class="action-link primary" href="${escapeHtml(href)}">${primaryLabel}</a>
                ${isDirectory
                  ? `<a class="action-link" href="#" ${secondaryAttrs}>${secondaryLabel}</a>`
                  : `<a class="action-link" ${secondaryAttrs}>${secondaryLabel}</a>`}
                ${deleteAction}
              </div>
            </div>
          </li>
        `;
      }).join("");

      list.querySelectorAll("[data-copy]").forEach((link) => {
        link.addEventListener("click", async (event) => {
          event.preventDefault();
          const value = link.getAttribute("data-copy");
          try {
            await navigator.clipboard.writeText(value);
            link.textContent = I18N.labelCopied;
            window.setTimeout(() => {
              link.textContent = I18N.labelCopy;
            }, 1200);
          } catch (error) {
            link.textContent = I18N.labelCopyFail;
          }
        });
      });

      list.querySelectorAll("[data-delete-name]").forEach((button) => {
        button.addEventListener("click", async () => {
          const name = button.getAttribute("data-delete-name");
          const href = button.getAttribute("data-delete-href");

          if (!window.confirm(I18N.labelDeleteConfirm.replace("{name}", name))) {
            return;
          }

          button.disabled = true;
          button.textContent = I18N.labelDeleting;

          try {
            const response = await fetch(`/_upload_api/${encodeURIComponent(name)}`, {
              method: "DELETE",
              cache: "no-store"
            });

            if (!response.ok && response.status !== 404) {
              throw new Error(`HTTP ${response.status}`);
            }

            items = items.filter((item) => joinPath(currentPath, item.name, false) !== href);
            button.textContent = I18N.labelDeleted;
            renderList();
          } catch (error) {
            button.disabled = false;
            button.textContent = `${I18N.labelDeleteFailed}: ${error.message}`;
          }
        });
      });
    }

    async function loadItems() {
      updateHeader();
      setState(I18N.stateLoading);

      try {
        if (isUploadRoot) {
          try {
            const sessionResponse = await fetch("/_session_status", { cache: "no-store" });
            canDeleteItems = sessionResponse.status === 204;
          } catch (error) {
            canDeleteItems = false;
          }
        }
        updateManagerPanel();

        const response = await fetch(dataUrl, { cache: "no-store" });
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const payload = await response.json();
        items = (Array.isArray(payload) ? payload : [])
          .filter((item) => item && typeof item.name === "string" && item.name !== "." && item.name !== "..")
          .sort((left, right) => {
            if (left.type === right.type) {
              return left.name.localeCompare(right.name, localeTag, { numeric: true, sensitivity: "base" });
            }
            return left.type === "directory" ? -1 : 1;
          });

        renderList();
      } catch (error) {
        setState(`${I18N.stateLoadFail}: ${error.message}`);
      }
    }

    filterInput.addEventListener("input", renderList);
    managerLogout.addEventListener("click", async () => {
      try {
        await fetch("/_session_logout", { cache: "no-store" });
      } catch (error) {
      }
      canDeleteItems = false;
      updateManagerPanel();
      renderList();
    });
    loadItems();
  </script>
</body>
</html>
