<!doctype html>
<html lang="${LANG_HTML}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>${SITE_TITLE} ${UPLOAD_TITLE_SUFFIX}</title>
  <style>
    :root {
      color-scheme: dark;
      --ink: #f5ead8;
      --text: #f7efe1;
      --muted: #b9aa92;
      --dim: #786e5e;
      --coal: #171512;
      --card: rgba(35, 30, 24, 0.8);
      --line: rgba(245, 218, 174, 0.18);
      --line-strong: rgba(245, 218, 174, 0.32);
      --accent: #e29b45;
      --accent-strong: #ffbf66;
      --accent-soft: rgba(226, 155, 69, 0.16);
      --green: #7fcda2;
      --green-soft: rgba(127, 205, 162, 0.15);
      --bad: #ff7d6e;
      --bad-soft: rgba(255, 125, 110, 0.13);
      --shadow: rgba(0, 0, 0, 0.44);
      --font-body: "LXGW WenKai", "Noto Serif SC", "Songti SC", "STSong", "Microsoft YaHei", serif;
      --font-ui: "Avenir Next", "Trebuchet MS", "Noto Sans SC", sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: var(--font-body);
      color: var(--text);
      background:
        radial-gradient(circle at 12% 14%, rgba(226, 155, 69, 0.24), transparent 30%),
        radial-gradient(circle at 86% 18%, rgba(127, 205, 162, 0.16), transparent 26%),
        radial-gradient(circle at 52% 92%, rgba(255, 125, 110, 0.12), transparent 28%),
        linear-gradient(135deg, #14110e 0%, #241b12 48%, #101412 100%);
      display: grid;
      place-items: center;
      padding: 30px;
      overflow-x: hidden;
    }

    body::before,
    body::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
    }

    body::before {
      opacity: 0.36;
      background-image:
        linear-gradient(rgba(245, 218, 174, 0.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245, 218, 174, 0.045) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: radial-gradient(circle at center, #000 0 58%, transparent 82%);
    }

    body::after {
      opacity: 0.09;
      background-image: radial-gradient(circle, #fff 0 0.7px, transparent 0.8px);
      background-size: 9px 9px;
      mix-blend-mode: screen;
    }

    main {
      position: relative;
      width: min(960px, 100%);
      border: 1px solid var(--line);
      border-radius: 34px;
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.07), transparent 34%),
        linear-gradient(180deg, rgba(40, 34, 27, 0.88), rgba(25, 22, 18, 0.92));
      box-shadow: 0 32px 120px var(--shadow), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      overflow: hidden;
      backdrop-filter: blur(18px);
      animation: page-in 460ms ease both;
    }

    main::before {
      content: "";
      position: absolute;
      inset: 14px;
      border: 1px solid rgba(245, 218, 174, 0.08);
      border-radius: 24px;
      pointer-events: none;
    }

    .hero {
      position: relative;
      padding: 42px 44px 34px;
      border-bottom: 1px solid var(--line);
      background:
        linear-gradient(110deg, rgba(226, 155, 69, 0.18), transparent 52%),
        radial-gradient(circle at 88% 14%, rgba(255, 191, 102, 0.17), transparent 26%);
      overflow: hidden;
    }

    .hero::after {
      content: "UPLOAD";
      position: absolute;
      right: 24px;
      bottom: -18px;
      font: 800 clamp(58px, 14vw, 152px) / 1 var(--font-ui);
      letter-spacing: -0.08em;
      color: rgba(245, 218, 174, 0.045);
      pointer-events: none;
    }

    .eyebrow {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      gap: 9px;
      padding: 7px 13px;
      border: 1px solid rgba(226, 155, 69, 0.24);
      border-radius: 999px;
      font: 700 12px / 1 var(--font-ui);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent-strong);
      background: rgba(226, 155, 69, 0.1);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
      margin-bottom: 18px;
    }

    .eyebrow::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: var(--accent-strong);
      box-shadow: 0 0 20px var(--accent-strong);
    }

    h1 {
      position: relative;
      z-index: 1;
      margin: 0 0 12px;
      max-width: 760px;
      font-size: clamp(34px, 5.2vw, 62px);
      line-height: 0.98;
      letter-spacing: -0.055em;
      text-wrap: balance;
    }

    p {
      position: relative;
      z-index: 1;
      margin: 0;
      color: var(--muted);
      line-height: 1.75;
    }

    code {
      border: 1px solid rgba(226, 155, 69, 0.24);
      border-radius: 10px;
      padding: 2px 7px;
      color: var(--accent-strong);
      background: rgba(226, 155, 69, 0.09);
      font-family: "Cascadia Code", "SFMono-Regular", monospace;
      font-size: 0.92em;
    }

    .panel {
      padding: 34px 44px 42px;
    }

    .nav {
      position: relative;
      z-index: 1;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 24px;
    }

    .actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .pick,
    button,
    a.link,
    a.nav-link {
      appearance: none;
      border: 1px solid var(--line);
      border-radius: 999px;
      font: 700 14px / 1 var(--font-ui);
      letter-spacing: 0.02em;
      text-decoration: none;
      padding: 12px 18px;
      cursor: pointer;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, opacity 160ms ease, box-shadow 160ms ease;
    }

    .pick,
    button {
      color: #21170b;
      border-color: transparent;
      background: linear-gradient(135deg, var(--accent-strong), #e58c32);
      box-shadow: 0 14px 34px rgba(226, 155, 69, 0.24);
    }

    a.link,
    a.nav-link,
    #logout {
      color: var(--text);
      background: rgba(255, 255, 255, 0.055);
      border: 1px solid var(--line);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    }

    .pick:hover,
    button:hover,
    a.link:hover,
    a.nav-link:hover {
      transform: translateY(-2px);
      border-color: var(--line-strong);
      background-color: rgba(255, 255, 255, 0.09);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    button[disabled] {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    input[type="file"] {
      display: none;
    }

    .hint {
      font-size: 15px;
      margin-bottom: 18px;
    }

    .auth-card {
      position: relative;
      max-width: 460px;
      display: grid;
      gap: 17px;
      margin: 0 auto;
      padding: 26px;
      border: 1px solid var(--line);
      border-radius: 28px;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.075), transparent 62%),
        rgba(255, 255, 255, 0.045);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
      overflow: hidden;
    }

    .auth-card::before {
      content: "";
      position: absolute;
      inset: 0 auto 0 0;
      width: 4px;
      background: linear-gradient(var(--accent-strong), rgba(127, 205, 162, 0.55));
    }

    .auth-grid {
      display: grid;
      gap: 15px;
    }

    .field {
      display: grid;
      gap: 9px;
    }

    .field label {
      font: 700 13px / 1 var(--font-ui);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dim);
    }

    .field input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 16px 18px;
      font: 18px / 1.3 var(--font-body);
      color: var(--text);
      background: rgba(13, 12, 10, 0.34);
      outline: none;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .field input:focus {
      border-color: rgba(255, 191, 102, 0.58);
      box-shadow: 0 0 0 4px rgba(226, 155, 69, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.07);
    }

    .auth-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }

    .auth-error,
    .auth-ok,
    .status,
    .tip {
      font-size: 14px;
      line-height: 1.65;
    }

    .auth-error,
    .status.err {
      color: var(--bad);
    }

    .auth-ok,
    .status.ok {
      color: var(--green);
    }

    .auth-meta,
    .tip {
      padding: 15px 17px;
      border-radius: 20px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.045);
      color: var(--muted);
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 0 0 18px;
      display: grid;
      gap: 12px;
    }

    li {
      position: relative;
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 16px 18px;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.075), transparent 58%),
        rgba(255, 255, 255, 0.045);
      overflow: hidden;
      animation: rise 240ms ease both;
    }

    li::before {
      content: "";
      position: absolute;
      inset: 0 auto 0 0;
      width: 4px;
      background: linear-gradient(var(--accent-strong), rgba(127, 205, 162, 0.55));
      opacity: 0.78;
    }

    .row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: baseline;
      margin-bottom: 11px;
    }

    .name {
      word-break: break-all;
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .meta {
      color: var(--muted);
      font: 700 13px / 1 var(--font-ui);
      white-space: nowrap;
    }

    .bar {
      height: 11px;
      border: 1px solid rgba(245, 218, 174, 0.12);
      border-radius: 999px;
      background: rgba(13, 12, 10, 0.34);
      overflow: hidden;
    }

    .bar > span {
      display: block;
      height: 100%;
      width: 0%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--accent-strong), var(--green));
      box-shadow: 0 0 24px rgba(127, 205, 162, 0.3);
      transition: width 120ms linear;
    }

    .status {
      margin-top: 9px;
      color: var(--muted);
      font-family: var(--font-ui);
    }

    .status a {
      color: var(--accent-strong);
      text-underline-offset: 4px;
    }

    [hidden] {
      display: none !important;
    }

    @keyframes page-in {
      from {
        opacity: 0;
        transform: translateY(12px) scale(0.992);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 760px) {
      body {
        padding: 14px;
      }

      main {
        border-radius: 26px;
      }

      .hero,
      .panel {
        padding-left: 22px;
        padding-right: 22px;
      }

      .row {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <main>
    <section class="hero">
      <div class="eyebrow">${UPLOAD_EYEBROW}</div>
      <h1>${UPLOAD_MAIN_TITLE}</h1>
      <p>${UPLOAD_SUBTITLE_PREFIX} <code>${UPLOAD_DIR}</code>${UPLOAD_SUBTITLE_SUFFIX}</p>
      <div class="nav">
        <a class="nav-link" href="/">${NAV_ROOT}</a>
        <a class="nav-link" href="/uploads/">${NAV_UPLOADS}</a>
        <a class="nav-link" href="${PROJECT_URL}" target="_blank" rel="noopener noreferrer">${NAV_PROJECT}</a>
      </div>
    </section>

    <section class="panel" id="auth-panel">
      <div class="auth-card">
        <div class="auth-grid">
          <div class="field">
            <label for="auth-user">${AUTH_USER_LABEL}</label>
            <input id="auth-user" name="username" autocomplete="username">
          </div>
          <div class="field">
            <label for="auth-pass">${AUTH_PASSWORD_LABEL}</label>
            <input id="auth-pass" name="password" type="password" autocomplete="current-password">
          </div>
        </div>
        <div class="auth-actions">
          <button id="auth-submit">${AUTH_SUBMIT}</button>
          <span class="auth-ok" id="auth-ok" hidden>${AUTH_OK}</span>
        </div>
        <div class="auth-error" id="auth-error" hidden></div>
        <div class="auth-meta">${AUTH_HINT}</div>
      </div>
    </section>

    <section class="panel" id="upload-panel" hidden>
      <div class="actions">
        <label class="pick" for="files">${UPLOAD_PICK}</label>
        <button id="start" disabled>${UPLOAD_START}</button>
        <a class="link" href="/uploads/">${UPLOAD_OPEN_DIR}</a>
        <button id="logout" type="button">${AUTH_LOGOUT}</button>
      </div>
      <p class="hint">${UPLOAD_HINT}</p>
      <input id="files" type="file" multiple>
      <ul id="queue"></ul>
      <div class="tip">${UPLOAD_DONE_PREFIX} <code>${ACCESS_BASE}/uploads/${UPLOAD_FILE_PLACEHOLDER}</code>${UPLOAD_DONE_SUFFIX}</div>
    </section>
  </main>

  <script>
    const I18N = {
      wait: ${JS_UPLOAD_WAIT},
      preparing: ${JS_UPLOAD_PREPARING},
      uploading: ${JS_UPLOAD_UPLOADING},
      done: ${JS_UPLOAD_DONE},
      openFile: ${JS_UPLOAD_OPEN_FILE},
      failed: ${JS_UPLOAD_FAILED},
      networkError: ${JS_UPLOAD_NET_ERROR},
      aborted: ${JS_UPLOAD_ABORTED},
      authRequired: ${JS_AUTH_REQUIRED},
      authFailed: ${JS_AUTH_FAILED},
      authNetwork: ${JS_AUTH_NETWORK},
      authChecking: ${JS_AUTH_CHECKING}
    };

    const authPanel = document.getElementById("auth-panel");
    const uploadPanel = document.getElementById("upload-panel");
    const authUser = document.getElementById("auth-user");
    const authPass = document.getElementById("auth-pass");
    const authSubmit = document.getElementById("auth-submit");
    const authError = document.getElementById("auth-error");
    const authOk = document.getElementById("auth-ok");
    const filesInput = document.getElementById("files");
    const startButton = document.getElementById("start");
    const logoutButton = document.getElementById("logout");
    const queue = document.getElementById("queue");

    const params = new URLSearchParams(location.search);
    const nextPath = params.get("next");

    let files = [];

    function showAuthError(message) {
      authError.hidden = false;
      authError.textContent = message;
      authOk.hidden = true;
    }

    function clearAuthState() {
      authError.hidden = true;
      authError.textContent = "";
      authOk.hidden = true;
    }

    function setAuthenticatedState() {
      if (nextPath && nextPath.startsWith("/") && !nextPath.startsWith("//")) {
        location.assign(nextPath);
        return;
      }
      authPanel.hidden = true;
      uploadPanel.hidden = false;
      authOk.hidden = false;
    }

    function clearAuthenticatedState() {
      uploadPanel.hidden = true;
      authPanel.hidden = false;
      clearAuthState();
      files = [];
      queue.innerHTML = "";
      filesInput.value = "";
      startButton.disabled = true;
    }

    async function verifyLogin() {
      const username = authUser.value.trim();
      const password = authPass.value;

      if (!username || !password) {
        showAuthError(I18N.authRequired);
        return;
      }

      clearAuthState();
      authSubmit.disabled = true;
      authSubmit.textContent = I18N.authChecking;

      try {
        const response = await fetch("/_session_login", {
          cache: "no-store",
          headers: {
            Authorization: `Basic ${btoa(`${username}:${password}`)}`
          }
        });

        if (response.status === 204) {
          setAuthenticatedState();
          authSubmit.textContent = "${AUTH_SUBMIT}";
          authSubmit.disabled = false;
          return;
        }

        showAuthError(I18N.authFailed);
      } catch (error) {
        showAuthError(I18N.authNetwork);
      }

      authSubmit.textContent = "${AUTH_SUBMIT}";
      authSubmit.disabled = false;
    }

    function formatBytes(bytes) {
      const units = ["B", "KB", "MB", "GB", "TB"];
      let value = bytes;
      let unit = units[0];
      for (let i = 0; i < units.length && value >= 1024; i += 1) {
        unit = units[i + 1] || units[i];
        if (value < 1024 || i === units.length - 1) {
          break;
        }
        value /= 1024;
      }
      return `${value.toFixed(value >= 100 || unit === "B" ? 0 : 1)} ${unit}`;
    }

    function renderQueue() {
      queue.innerHTML = "";
      for (const file of files) {
        const item = document.createElement("li");
        item.innerHTML = `
          <div class="row">
            <div class="name"></div>
            <div class="meta">${formatBytes(file.size)}</div>
          </div>
          <div class="bar"><span></span></div>
          <div class="status">${I18N.wait}</div>
        `;
        item.querySelector(".name").textContent = file.name;
        file._elements = {
          bar: item.querySelector(".bar > span"),
          status: item.querySelector(".status")
        };
        queue.appendChild(item);
      }
      startButton.disabled = files.length === 0;
    }

    function setStatus(file, message, className) {
      file._elements.status.textContent = message;
      file._elements.status.className = `status ${className || ""}`.trim();
    }

    function setProgress(file, value) {
      file._elements.bar.style.width = `${Math.max(0, Math.min(100, value))}%`;
    }

    function uploadFile(file) {
      return new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        const uploadTarget = `/_upload_api/${encodeURIComponent(file.name)}`;
        const publicTarget = `/uploads/${encodeURIComponent(file.name)}`;
        xhr.open("PUT", uploadTarget);
        xhr.responseType = "text";

        xhr.upload.addEventListener("progress", (event) => {
          if (!event.lengthComputable) {
            return;
          }
          setProgress(file, (event.loaded / event.total) * 100);
          setStatus(file, `${I18N.uploading} ${Math.round((event.loaded / event.total) * 100)}%`);
        });

        xhr.addEventListener("load", () => {
          if (xhr.status >= 200 && xhr.status < 300) {
            setProgress(file, 100);
            const link = document.createElement("a");
            link.href = publicTarget;
            link.textContent = I18N.openFile;
            file._elements.status.innerHTML = "";
            file._elements.status.className = "status ok";
            file._elements.status.append(`${I18N.done} `, link);
            resolve();
            return;
          }
          reject(new Error(`HTTP ${xhr.status}`));
        });

        xhr.addEventListener("error", () => reject(new Error(I18N.networkError)));
        xhr.addEventListener("abort", () => reject(new Error(I18N.aborted)));
        xhr.setRequestHeader("Content-Type", "application/octet-stream");
        xhr.send(file);
      });
    }

    authSubmit.addEventListener("click", verifyLogin);
    authPass.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        verifyLogin();
      }
    });

    filesInput.addEventListener("change", () => {
      files = Array.from(filesInput.files || []);
      renderQueue();
    });

    logoutButton.addEventListener("click", async () => {
      try {
        await fetch("/_session_logout", { cache: "no-store" });
      } catch (error) {
      }
      clearAuthenticatedState();
    });

    startButton.addEventListener("click", async () => {
      startButton.disabled = true;
      for (const file of files) {
        try {
          setStatus(file, I18N.preparing);
          await uploadFile(file);
        } catch (error) {
          if (String(error.message).includes("401")) {
            clearAuthenticatedState();
            showAuthError(I18N.authFailed);
            return;
          }
          setStatus(file, `${I18N.failed}: ${error.message}`, "err");
        }
      }
      if (files.length > 0) {
        filesInput.value = "";
        files = [];
      }
    });

    (async () => {
      try {
        const response = await fetch("/_session_status", { cache: "no-store" });

        if (response.status === 204) {
          setAuthenticatedState();
        } else {
          clearAuthenticatedState();
        }
      } catch (error) {
        clearAuthenticatedState();
      }
    })();
  </script>
</body>
</html>
