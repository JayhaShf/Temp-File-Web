<!doctype html>
<html lang="${LANG_HTML}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>${SITE_TITLE} ${UPLOAD_TITLE_SUFFIX}</title>
  <style>
    :root {
      color-scheme: light;
      --card: rgba(255, 252, 247, 0.92);
      --text: #1f1a16;
      --muted: #6d6258;
      --line: rgba(86, 72, 58, 0.18);
      --accent: #b34d22;
      --accent-strong: #8f3611;
      --accent-soft: rgba(179, 77, 34, 0.12);
      --ok: #226f54;
      --bad: #aa2e25;
      --shadow: rgba(73, 53, 39, 0.12);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Noto Sans", "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(179, 77, 34, 0.16), transparent 34%),
        radial-gradient(circle at bottom right, rgba(34, 111, 84, 0.16), transparent 28%),
        linear-gradient(135deg, #f6f0e8, #efe6d7 46%, #f8f4ed);
      display: grid;
      place-items: center;
      padding: 24px;
    }

    main {
      width: min(920px, 100%);
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 22px;
      box-shadow: 0 24px 80px var(--shadow);
      overflow: hidden;
      backdrop-filter: blur(10px);
    }

    .hero {
      padding: 32px 32px 24px;
      border-bottom: 1px solid var(--line);
      background: linear-gradient(135deg, rgba(179, 77, 34, 0.08), rgba(255, 255, 255, 0));
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 13px;
      color: var(--accent-strong);
      background: var(--accent-soft);
      margin-bottom: 14px;
    }

    h1 {
      margin: 0 0 10px;
      font-size: clamp(28px, 4vw, 40px);
      line-height: 1.05;
    }

    p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .panel {
      padding: 28px 32px 32px;
    }

    .nav {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .pick,
    button,
    a.link,
    a.nav-link {
      appearance: none;
      border: 0;
      border-radius: 999px;
      font: inherit;
      text-decoration: none;
      padding: 12px 18px;
      cursor: pointer;
      transition: transform 140ms ease, background 140ms ease, opacity 140ms ease;
    }

    .pick,
    button {
      color: #fff7f1;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      box-shadow: 0 10px 30px rgba(179, 77, 34, 0.18);
    }

    a.link,
    a.nav-link {
      color: var(--text);
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--line);
    }

    .pick:hover,
    button:hover,
    a.link:hover,
    a.nav-link:hover {
      transform: translateY(-1px);
    }

    button[disabled] {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    input[type="file"] {
      display: none;
    }

    .hint {
      font-size: 14px;
      margin-bottom: 18px;
    }

    .auth-card {
      max-width: 420px;
      display: grid;
      gap: 16px;
      margin: 0 auto;
      padding: 22px;
      border: 1px solid var(--line);
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.72);
    }

    .auth-grid {
      display: grid;
      gap: 14px;
    }

    .field {
      display: grid;
      gap: 8px;
    }

    .field label {
      font-size: 14px;
      color: var(--muted);
    }

    .field input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 14px 16px;
      font: inherit;
      color: var(--text);
      background: rgba(255, 255, 255, 0.88);
      outline: none;
    }

    .field input:focus {
      border-color: rgba(179, 77, 34, 0.48);
      box-shadow: 0 0 0 4px rgba(179, 77, 34, 0.08);
    }

    .auth-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }

    .auth-error,
    .auth-ok,
    .status,
    .tip {
      font-size: 14px;
      line-height: 1.6;
    }

    .auth-error,
    .status.err {
      color: var(--bad);
    }

    .auth-ok,
    .status.ok {
      color: var(--ok);
    }

    .auth-meta,
    .tip {
      padding: 14px 16px;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.68);
      color: var(--muted);
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 12px;
    }

    li {
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 14px 16px;
      background: rgba(255, 255, 255, 0.76);
    }

    .row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: baseline;
      margin-bottom: 8px;
    }

    .name {
      word-break: break-all;
      font-weight: 600;
    }

    .meta {
      color: var(--muted);
      font-size: 13px;
      white-space: nowrap;
    }

    .bar {
      height: 10px;
      border-radius: 999px;
      background: rgba(109, 98, 88, 0.12);
      overflow: hidden;
    }

    .bar > span {
      display: block;
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #d36b3c, #226f54);
      transition: width 120ms linear;
    }

    .status {
      margin-top: 8px;
      color: var(--muted);
    }

    [hidden] {
      display: none !important;
    }
  </style>
</head>
<body>
  <main>
    <section class="hero">
      <div class="eyebrow">${UPLOAD_EYEBROW}</div>
      <h1>${UPLOAD_MAIN_TITLE}</h1>
      <p>${UPLOAD_SUBTITLE_PREFIX} <code>${UPLOAD_DIR}</code>${UPLOAD_SUBTITLE_SUFFIX}</p>
      <div class="nav">
        <a class="nav-link" href="/">${NAV_ROOT}</a>
        <a class="nav-link" href="/uploads/">${NAV_UPLOADS}</a>
      </div>
    </section>

    <section class="panel" id="auth-panel">
      <div class="auth-card">
        <div class="auth-grid">
          <div class="field">
            <label for="auth-user">${AUTH_USER_LABEL}</label>
            <input id="auth-user" name="username" autocomplete="username">
          </div>
          <div class="field">
            <label for="auth-pass">${AUTH_PASSWORD_LABEL}</label>
            <input id="auth-pass" name="password" type="password" autocomplete="current-password">
          </div>
        </div>
        <div class="auth-actions">
          <button id="auth-submit">${AUTH_SUBMIT}</button>
          <span class="auth-ok" id="auth-ok" hidden>${AUTH_OK}</span>
        </div>
        <div class="auth-error" id="auth-error" hidden></div>
        <div class="auth-meta">${AUTH_HINT}</div>
      </div>
    </section>

    <section class="panel" id="upload-panel" hidden>
      <div class="actions">
        <label class="pick" for="files">${UPLOAD_PICK}</label>
        <button id="start" disabled>${UPLOAD_START}</button>
        <a class="link" href="/uploads/">${UPLOAD_OPEN_DIR}</a>
      </div>
      <p class="hint">${UPLOAD_HINT}</p>
      <input id="files" type="file" multiple>
      <ul id="queue"></ul>
      <div class="tip">${UPLOAD_DONE_PREFIX} <code>${ACCESS_BASE}/uploads/${UPLOAD_FILE_PLACEHOLDER}</code>${UPLOAD_DONE_SUFFIX}</div>
    </section>
  </main>

  <script>
    const I18N = {
      wait: ${JS_UPLOAD_WAIT},
      preparing: ${JS_UPLOAD_PREPARING},
      uploading: ${JS_UPLOAD_UPLOADING},
      done: ${JS_UPLOAD_DONE},
      openFile: ${JS_UPLOAD_OPEN_FILE},
      failed: ${JS_UPLOAD_FAILED},
      networkError: ${JS_UPLOAD_NET_ERROR},
      aborted: ${JS_UPLOAD_ABORTED},
      authRequired: ${JS_AUTH_REQUIRED},
      authFailed: ${JS_AUTH_FAILED},
      authNetwork: ${JS_AUTH_NETWORK},
      authChecking: ${JS_AUTH_CHECKING}
    };

    const authPanel = document.getElementById("auth-panel");
    const uploadPanel = document.getElementById("upload-panel");
    const authUser = document.getElementById("auth-user");
    const authPass = document.getElementById("auth-pass");
    const authSubmit = document.getElementById("auth-submit");
    const authError = document.getElementById("auth-error");
    const authOk = document.getElementById("auth-ok");
    const filesInput = document.getElementById("files");
    const startButton = document.getElementById("start");
    const queue = document.getElementById("queue");

    let files = [];
    let authHeader = "";

    function encodeBasicAuth(username, password) {
      return `Basic ${btoa(`${username}:${password}`)}`;
    }

    function showAuthError(message) {
      authError.hidden = false;
      authError.textContent = message;
      authOk.hidden = true;
    }

    function clearAuthState() {
      authError.hidden = true;
      authError.textContent = "";
      authOk.hidden = true;
    }

    async function verifyLogin() {
      const username = authUser.value.trim();
      const password = authPass.value;

      if (!username || !password) {
        showAuthError(I18N.authRequired);
        return;
      }

      clearAuthState();
      authSubmit.disabled = true;
      authSubmit.textContent = I18N.authChecking;

      try {
        const header = encodeBasicAuth(username, password);
        const response = await fetch("/_auth_upload", {
          cache: "no-store",
          headers: {
            Authorization: header
          }
        });

        if (response.status === 204) {
          authHeader = header;
          authPanel.hidden = true;
          uploadPanel.hidden = false;
          authOk.hidden = false;
          authSubmit.textContent = "${AUTH_SUBMIT}";
          authSubmit.disabled = false;
          return;
        }

        showAuthError(I18N.authFailed);
      } catch (error) {
        showAuthError(I18N.authNetwork);
      }

      authSubmit.textContent = "${AUTH_SUBMIT}";
      authSubmit.disabled = false;
    }

    function formatBytes(bytes) {
      const units = ["B", "KB", "MB", "GB", "TB"];
      let value = bytes;
      let unit = units[0];
      for (let i = 0; i < units.length && value >= 1024; i += 1) {
        unit = units[i + 1] || units[i];
        if (value < 1024 || i === units.length - 1) {
          break;
        }
        value /= 1024;
      }
      return `${value.toFixed(value >= 100 || unit === "B" ? 0 : 1)} ${unit}`;
    }

    function renderQueue() {
      queue.innerHTML = "";
      for (const file of files) {
        const item = document.createElement("li");
        item.innerHTML = `
          <div class="row">
            <div class="name"></div>
            <div class="meta">${formatBytes(file.size)}</div>
          </div>
          <div class="bar"><span></span></div>
          <div class="status">${I18N.wait}</div>
        `;
        item.querySelector(".name").textContent = file.name;
        file._elements = {
          bar: item.querySelector(".bar > span"),
          status: item.querySelector(".status")
        };
        queue.appendChild(item);
      }
      startButton.disabled = files.length === 0;
    }

    function setStatus(file, message, className) {
      file._elements.status.textContent = message;
      file._elements.status.className = `status ${className || ""}`.trim();
    }

    function setProgress(file, value) {
      file._elements.bar.style.width = `${Math.max(0, Math.min(100, value))}%`;
    }

    function uploadFile(file) {
      return new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        const target = `/uploads/${encodeURIComponent(file.name)}`;
        xhr.open("PUT", target);
        xhr.responseType = "text";
        xhr.setRequestHeader("Authorization", authHeader);

        xhr.upload.addEventListener("progress", (event) => {
          if (!event.lengthComputable) {
            return;
          }
          setProgress(file, (event.loaded / event.total) * 100);
          setStatus(file, `${I18N.uploading} ${Math.round((event.loaded / event.total) * 100)}%`);
        });

        xhr.addEventListener("load", () => {
          if (xhr.status >= 200 && xhr.status < 300) {
            setProgress(file, 100);
            const link = document.createElement("a");
            link.href = target;
            link.textContent = I18N.openFile;
            file._elements.status.innerHTML = "";
            file._elements.status.className = "status ok";
            file._elements.status.append(`${I18N.done} `, link);
            resolve();
            return;
          }
          reject(new Error(`HTTP ${xhr.status}`));
        });

        xhr.addEventListener("error", () => reject(new Error(I18N.networkError)));
        xhr.addEventListener("abort", () => reject(new Error(I18N.aborted)));
        xhr.setRequestHeader("Content-Type", "application/octet-stream");
        xhr.send(file);
      });
    }

    authSubmit.addEventListener("click", verifyLogin);
    authPass.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        verifyLogin();
      }
    });

    filesInput.addEventListener("change", () => {
      files = Array.from(filesInput.files || []);
      renderQueue();
    });

    startButton.addEventListener("click", async () => {
      startButton.disabled = true;
      for (const file of files) {
        try {
          setStatus(file, I18N.preparing);
          await uploadFile(file);
        } catch (error) {
          setStatus(file, `${I18N.failed}: ${error.message}`, "err");
        }
      }
      if (files.length > 0) {
        filesInput.value = "";
        files = [];
      }
    });
  </script>
</body>
</html>
