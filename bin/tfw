auth_user() {
  if [[ -f "$AUTH_FILE" ]]; then
    awk -F: 'NR==1{print $1; exit}' "$AUTH_FILE"
  fi
}

set_auth_file_permissions() {
  local owner_group

  chmod 0640 "$AUTH_FILE"
  if id -u "$TFW_USER" >/dev/null 2>&1; then
    owner_group="$(id -gn "$TFW_USER")"
    chown root:"$owner_group" "$AUTH_FILE"
  else
    chown root:root "$AUTH_FILE"
  fi
}

path_state() {
  local path="$1"
  if [[ -d "$path" ]]; then
    echo "$(msg ok_dir)"
  elif [[ -f "$path" ]]; then
    echo "$(msg ok_file)"
  else
    echo "$(msg missing)"
  fi
}

write_state() {
  local path="$1"
  if [[ -d "$path" && -w "$path" ]]; then
    echo "$(msg ok_writable)"
  elif [[ -e "$path" ]]; then
    echo "$(msg readonly)"
  else
    echo "$(msg missing)"
  fi
}

read_state() {
  local path="$1"
  if [[ -r "$path" ]]; then
    echo "$(msg ok_readable)"
  elif [[ -e "$path" ]]; then
    echo "$(msg unreadable)"
  else
    echo "$(msg missing)"
  fi
}

print_kv() {
  printf '%-15s: %s\n' "$1" "$2"
}

count_entries() {
  local dir="$1"
  local kind="${2:-all}"

  if [[ ! -d "$dir" ]]; then
    echo 0
    return 0
  fi

  if [[ "$kind" == "files" ]]; then
    find "$dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | awk '{print $1}'
  else
    find "$dir" -mindepth 1 -maxdepth 1 2>/dev/null | wc -l | awk '{print $1}'
  fi
}

dir_size() {
  local dir="$1"

  if [[ -d "$dir" ]]; then
    du -sh "$dir" 2>/dev/null | awk '{print $1}'
  else
    echo 0
  fi
}

free_space() {
  local path="$1"
  local value

  if [[ -e "$path" || -d "$(dirname "$path")" ]]; then
    value="$(df -h "$path" 2>/dev/null | awk 'NR==2{print $4}')"
  fi

  echo "${value:--}"
}

resolve_dir() {
  case "${1:-root}" in
    ""|root)
      printf '%s\n' "$DATA_DIR"
      ;;
    upload|uploads)
      printf '%s\n' "$UPLOAD_DIR"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

http_code() {
  local url="$1"
  local auth="${2:-}"
  local method="${3:-GET}"
  local code
  if [[ -n "$auth" ]]; then
    code="$(curl -sk -o /dev/null -w '%{http_code}' -X "$method" --resolve "${resolve_host}:${url_port}:${resolve_ip}" -u "$auth" "$url" 2>/dev/null)" || {
      echo ERR
      return 0
    }
  else
    code="$(curl -sk -o /dev/null -w '%{http_code}' -X "$method" --resolve "${resolve_host}:${url_port}:${resolve_ip}" "$url" 2>/dev/null)" || {
      echo ERR
      return 0
    }
  fi
  echo "$code"
}

show_time() {
  echo "$(printf '%-15s: %s' "$(msg host_time)" "$(date '+%Y-%m-%d %H:%M:%S %Z (%z)')")"
  echo "$(printf '%-15s: %s' "$(msg utc_time)" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')")"
  echo "$(printf '%-15s: %s' "$(msg host_name)" "$(hostname)")"
}

show_urls() {
  echo "$(printf '%-15s: %s' "$(msg root_url)" "$url_root")"
  echo "$(printf '%-15s: %s' "$(msg upload_page)" "$url_upload")"
  echo "$(printf '%-15s: %s' "$(msg listing_api)" "$url_listing")"
  echo "$(printf '%-15s: %s' "$(msg project_url)" "$PROJECT_URL")"
}

show_info() {
  local acme_enabled_text auth_user_name
  if [[ "$INSTALL_ACME" == "1" ]]; then
    acme_enabled_text="$(msg enabled_yes)"
  else
    acme_enabled_text="$(msg enabled_no)"
  fi
  auth_user_name="$(auth_user || true)"

  echo "$(printf '%-15s: %s (%s)' "$(msg runtime_config)" "$CONFIG_FILE" "$(path_state "$CONFIG_FILE")")"
  echo "$(printf '%-15s: %s' "$(msg language)" "$LANGUAGE")"
  echo "$(printf '%-15s: %s' "$(msg site_mode)" "$SITE_MODE")"
  echo "$(printf '%-15s: %s' "$(msg site_title)" "$SITE_TITLE")"
  echo "$(printf '%-15s: %s' "$(msg project_url)" "$PROJECT_URL")"
  echo "$(printf '%-15s: %s' "$(msg site_id)" "$SITE_ID")"
  if [[ -n "$DOMAIN" ]]; then
    echo "$(printf '%-15s: %s' "$(msg domain)" "$DOMAIN")"
  fi
  echo "$(printf '%-15s: %s' "$(msg access_host)" "$ACCESS_HOST")"
  echo "$(printf '%-15s: %s' "$(msg http_port)" "$HTTP_PORT")"
  echo "$(printf '%-15s: %s' "$(msg https_port)" "$HTTPS_PORT")"
  echo "$(printf '%-15s: %s' "$(msg resolve_ip)" "$IP")"
  echo "$(printf '%-15s: %s (%s)' "$(msg site_dir)" "$SITE_DIR" "$(path_state "$SITE_DIR")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg config_file)" "$CONF" "$(path_state "$CONF")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg auth_file)" "$AUTH_FILE" "$(path_state "$AUTH_FILE")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg data_dir)" "$DATA_DIR" "$(path_state "$DATA_DIR")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg upload_dir)" "$UPLOAD_DIR" "$(path_state "$UPLOAD_DIR")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg browser_html)" "$BROWSER_HTML" "$(path_state "$BROWSER_HTML")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg upload_html)" "$UPLOAD_HTML" "$(path_state "$UPLOAD_HTML")")"
  echo "$(printf '%-15s: %s' "$(msg acme_enabled)" "$acme_enabled_text")"
  if [[ "$INSTALL_ACME" == "1" ]]; then
    echo "$(printf '%-15s: %s (%s)' "$(msg acme_webroot)" "$ACME_WEBROOT" "$(path_state "$ACME_WEBROOT")")"
  fi
  echo "$(printf '%-15s: %s (%s)' "$(msg cert_file)" "$CERT_FILE" "$(path_state "$CERT_FILE")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg key_file)" "$KEY_FILE" "$(path_state "$KEY_FILE")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg access_log)" "$ACCESS_LOG" "$(path_state "$ACCESS_LOG")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg error_log)" "$ERROR_LOG" "$(path_state "$ERROR_LOG")")"
  echo "$(printf '%-15s: %s' "$(msg auth_user)" "${auth_user_name:-$(msg none)}")"
  echo
  show_urls
}

test_nginx() {
  need nginx
  nginx -t
}

show_status() {
  local listing_payload listing_count auth_user_name nginx_test_text nginx_process_text
  local root_code listing_code upload_code session_code upload_api_code login_verify_code summary_text
  if ! command -v nginx >/dev/null 2>&1; then
    echo "$(msg missing_command nginx)" >&2
    exit 1
  fi
  if ! command -v curl >/dev/null 2>&1; then
    echo "$(msg missing_command curl)" >&2
    exit 1
  fi

  listing_payload="$(curl -sk --resolve "${resolve_host}:${url_port}:${resolve_ip}" "$url_listing" 2>/dev/null || true)"
  listing_count="$(printf '%s' "$listing_payload" | grep -o '"name":"' | wc -l | awk '{print $1}')"
  auth_user_name="$(auth_user || true)"
  if nginx -t >/dev/null 2>&1; then
    nginx_test_text="$(msg ok_file)"
  else
    nginx_test_text="$(msg fail)"
  fi
  if pgrep -x nginx >/dev/null 2>&1; then
    nginx_process_text="$(msg ok_file) ($(pgrep -xc nginx))"
  else
    nginx_process_text="$(msg fail)"
  fi

  echo "$(printf '%-15s: %s' "$(msg status_time)" "$(date '+%Y-%m-%d %H:%M:%S %Z (%z)')")"
  echo "$(printf '%-15s: %s' "$(msg site_mode)" "$SITE_MODE")"
  if [[ -n "$DOMAIN" ]]; then
    echo "$(printf '%-15s: %s' "$(msg domain)" "$DOMAIN")"
  fi
  echo "$(printf '%-15s: %s' "$(msg access_host)" "$ACCESS_HOST")"
  echo "$(printf '%-15s: %s' "$(msg resolve_ip)" "$IP")"
  echo "$(printf '%-15s: %s (%s)' "$(msg config_file)" "$CONF" "$(path_state "$CONF")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg auth_file)" "$AUTH_FILE" "$(path_state "$AUTH_FILE")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg cert_file)" "$CERT_FILE" "$(path_state "$CERT_FILE")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg key_file)" "$KEY_FILE" "$(path_state "$KEY_FILE")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg data_dir)" "$DATA_DIR" "$(path_state "$DATA_DIR")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg upload_dir)" "$UPLOAD_DIR" "$(path_state "$UPLOAD_DIR")")"
  echo "$(printf '%-15s: %s' "$(msg free_space)" "$(free_space "$DATA_DIR")")"
  echo "$(printf '%-15s: %s' "$(msg nginx_test)" "$nginx_test_text")"
  echo "$(printf '%-15s: %s' "$(msg nginx_process)" "$nginx_process_text")"
  echo "$(printf '%-15s: %s' "$(msg auth_user)" "${auth_user_name:-$(msg none)}")"
  echo "$(printf '%-15s: %s' "$(msg root_items)" "$(count_entries "$DATA_DIR")")"
  echo "$(printf '%-15s: %s' "$(msg upload_files)" "$(count_entries "$UPLOAD_DIR" files)")"
  echo "$(printf '%-15s: %s' "$(msg upload_size)" "$(dir_size "$UPLOAD_DIR")")"
  root_code="$(http_code "$url_root")"
  listing_code="$(http_code "$url_listing")"
  upload_code="$(http_code "$url_upload")"
  session_code="$(http_code "$url_session_status")"
  upload_api_code="$(http_code "${url_scheme}://${url_authority}/_upload_api/.tfw-status-probe" "" OPTIONS)"
  if [[ -n "$auth_user_name" ]]; then
    login_verify_code="$(http_code "$url_session_login" "${auth_user_name}:__tfw_invalid_password__")"
  else
    login_verify_code="$(msg none)"
  fi

  if [[ "$root_code" == "200" && "$listing_code" == "200" && "$upload_code" == "200" ]]; then
    summary_text="$(msg summary_ok)"
  elif [[ "$root_code" == "200" || "$listing_code" == "200" || "$upload_code" == "200" ]]; then
    summary_text="$(msg summary_partial)"
  else
    summary_text="$(msg summary_fail)"
  fi

  echo "$(printf '%-15s: %s' "$(msg summary)" "$summary_text")"
  echo "$(printf '%-15s: %s' "$(msg root_page)" "$root_code")"
  echo "$(printf '%-15s: %s' "$(msg listing_json)" "$listing_code")"
  echo "$(printf '%-15s: %s' "$(msg upload_expect)" "$upload_code")"
  echo "$(printf '%-15s: %s' "$(msg session_status)" "$session_code")"
  echo "$(printf '%-15s: %s' "$(msg upload_api_expect)" "$upload_api_code")"
  echo "$(printf '%-15s: %s' "$(msg login_verify)" "$login_verify_code")"
  echo "$(printf '%-15s: %s' "$(msg listing_count)" "${listing_count:-0}")"
}

list_dir() {
  local target="${1:-root}"
  local dir

  dir="$(resolve_dir "$target")"
  if [[ ! -d "$dir" ]]; then
    echo "$(msg dir_not_found "$dir")" >&2
    exit 1
  fi

  echo "$(printf '%-15s: %s' "$(msg directory)" "$dir")"
  ls -lah "$dir"
}

show_logs() {
  local target="${1:-access}"
  local lines="${2:-50}"
  local file

  [[ "$lines" =~ ^[0-9]+$ ]] || {
    echo "$(msg lines_integer)" >&2
    exit 1
  }

  case "$target" in
    access)
      file="$ACCESS_LOG"
      ;;
    error)
      file="$ERROR_LOG"
      ;;
    all)
      (show_logs access "$lines") || true
      echo
      (show_logs error "$lines") || true
      return 0
      ;;
    *)
      echo "$(msg unknown_log_target "$target")" >&2
      echo "$(msg logs_usage)" >&2
      exit 1
      ;;
  esac

  [[ -f "$file" ]] || {
    echo "$(msg log_not_found "$file")" >&2
    exit 1
  }

  echo "$(printf '%-15s: %s' "$(msg log_file)" "$file")"
  echo "$(printf '%-15s: %s' "$(msg lines)" "$lines")"
  tail -n "$lines" "$file"
}

restart_nginx() {
  need_root
  need nginx

  nginx -t
  if command -v systemctl >/dev/null 2>&1; then
    if systemctl restart nginx; then
      echo "$(printf '%-15s: %s' "$(msg restart_systemctl)" "$(msg restart_ok)")"
    else
      nginx -s reload
      echo "$(printf '%-15s: %s' "$(msg restart_reload)" "$(msg reload_ok)")"
    fi
  else
    nginx -s reload
    echo "$(printf '%-15s: %s' "$(msg restart_reload)" "$(msg reload_ok)")"
  fi
  sleep 1
  show_status
}

rotate_passwd() {
  need_root
  need openssl

  local user input_user password password2 backup hash code current_user
  [[ $# -le 2 ]] || {
    echo "$(msg passwd_usage)" >&2
    exit 1
  }

  current_user="$(auth_user || true)"
  user="${1:-$current_user}"
  user="${user:-uploader}"
  password="${2:-}"

  if [[ -t 0 ]]; then
    if [[ $# -eq 0 ]]; then
      read -r -p "$(msg passwd_user_prompt) [${user}]: " input_user
      user="${input_user:-$user}"
    fi

    if [[ $# -lt 2 ]]; then
      read -r -s -p "$(msg passwd_new_prompt): " password
      printf '\n'
      if [[ -n "${password:-}" ]]; then
        read -r -s -p "$(msg passwd_confirm): " password2
        printf '\n'
        [[ "$password" == "$password2" ]] || {
          echo "$(msg passwd_mismatch)" >&2
          exit 1
        }
      fi
    fi
  fi

  if [[ -z "${password:-}" ]]; then
    password="$(openssl rand -base64 18 | tr -d '=+/\n' | cut -c1-20)"
  fi

  backup=""
  if [[ -f "$AUTH_FILE" ]]; then
    backup="${AUTH_FILE}.bak-$(date +%Y%m%d%H%M%S)"
    cp "$AUTH_FILE" "$backup"
  else
    mkdir -p "$(dirname "$AUTH_FILE")"
  fi

  hash="$(openssl passwd -apr1 "$password")"
  umask 077
  printf '%s:%s\n' "$user" "$hash" > "$AUTH_FILE"
  set_auth_file_permissions

  if ! awk -F: 'NR==1 && NF>=2 && $1 != "" {ok=1} END {exit ok ? 0 : 1}' "$AUTH_FILE"; then
    if [[ -n "$backup" ]]; then
      cp "$backup" "$AUTH_FILE"
    else
      rm -f "$AUTH_FILE"
    fi
    echo "$(msg passwd_verify_fail)" >&2
    exit 1
  fi

  code="$(http_code "$url_session_login" "${user}:${password}")"

  echo "$(printf '%-15s: %s' "$(msg auth_user)" "$user")"
  echo "password        : $password"
  echo "$(printf '%-15s: %s' "$(msg backup)" "${backup:-$(msg none)}")"
  echo "$(printf '%-15s: %s' "$(msg local_verify)" "$(msg ok_file)")"
  echo "$(printf '%-15s: %s' "$(msg remote_verify)" "$code")"
}

show_cert() {
  local acme_enabled_text
  if [[ "$INSTALL_ACME" == "1" ]]; then
    acme_enabled_text="$(msg enabled_yes)"
  else
    acme_enabled_text="$(msg enabled_no)"
  fi

  echo "$(printf '%-15s: %s' "$(msg site_mode)" "$SITE_MODE")"
  echo "$(printf '%-15s: %s' "$(msg acme_enabled)" "$acme_enabled_text")"
  if [[ "$INSTALL_ACME" == "1" ]]; then
    echo "$(printf '%-15s: %s (%s)' "$(msg acme_bin)" "$ACME_BIN" "$(path_state "$ACME_BIN")")"
    echo "$(printf '%-15s: %s (%s)' "$(msg acme_home)" "$ACME_HOME" "$(path_state "$ACME_HOME")")"
  fi
  echo "$(printf '%-15s: %s (%s)' "$(msg cert_file)" "$CERT_FILE" "$(path_state "$CERT_FILE")")"
  echo "$(printf '%-15s: %s (%s)' "$(msg key_file)" "$KEY_FILE" "$(path_state "$KEY_FILE")")"
}

show_auth() {
  need curl

  local auth_user_name session_code upload_api_code invalid_code valid_code provided_user provided_password
  provided_user="${1:-${TFW_AUTH_USER:-}}"
  provided_password="${2:-${TFW_AUTH_PASSWORD:-}}"

  [[ $# -le 2 ]] || {
    echo "$(msg auth_usage)" >&2
    exit 1
  }

  auth_user_name="$(auth_user || true)"
  session_code="$(http_code "$url_session_status")"
  upload_api_code="$(http_code "${url_scheme}://${url_authority}/_upload_api/.tfw-auth-probe" "" OPTIONS)"

  if [[ -n "$auth_user_name" ]]; then
    invalid_code="$(http_code "$url_session_login" "${auth_user_name}:__tfw_invalid_password__")"
  else
    invalid_code="$(msg none)"
  fi

  if [[ -n "$provided_user" && -n "$provided_password" ]]; then
    valid_code="$(http_code "$url_session_login" "${provided_user}:${provided_password}")"
  else
    valid_code="$(msg none)"
  fi

  print_kv "$(msg auth_current)" "${auth_user_name:-$(msg none)}"
  print_kv "$(msg auth_file)" "$AUTH_FILE ($(path_state "$AUTH_FILE"), $(read_state "$AUTH_FILE"))"
  print_kv "$(msg auth_endpoint)" "$url_session_login"
  print_kv "$(msg session_status)" "$session_code"
  print_kv "$(msg auth_invalid)" "$invalid_code"
  print_kv "$(msg auth_valid)" "$valid_code"
  print_kv "$(msg upload_api_options)" "$upload_api_code"
}

show_config() {
  print_kv "$(msg runtime_config)" "$CONFIG_FILE ($(path_state "$CONFIG_FILE"), $(read_state "$CONFIG_FILE"))"
  if [[ -f "$CONFIG_FILE" ]]; then
    echo
    echo "$(msg config_dump):"
    sed -n '1,240p' "$CONFIG_FILE"
  fi
}

show_doctor() {
  local auth_user_name
  auth_user_name="$(auth_user || true)"

  print_kv "$(msg runtime_config)" "$CONFIG_FILE ($(path_state "$CONFIG_FILE"), $(read_state "$CONFIG_FILE"))"
  print_kv "$(msg config_file)" "$CONF ($(path_state "$CONF"), $(read_state "$CONF"))"
  print_kv "$(msg site_dir)" "$SITE_DIR ($(path_state "$SITE_DIR"))"
  print_kv "$(msg data_dir)" "$DATA_DIR ($(path_state "$DATA_DIR"), $(write_state "$DATA_DIR"))"
  print_kv "$(msg upload_dir)" "$UPLOAD_DIR ($(path_state "$UPLOAD_DIR"), $(write_state "$UPLOAD_DIR"))"
  print_kv "$(msg auth_file)" "$AUTH_FILE ($(path_state "$AUTH_FILE"), $(read_state "$AUTH_FILE"))"
  print_kv "$(msg browser_html)" "$BROWSER_HTML ($(path_state "$BROWSER_HTML"), $(read_state "$BROWSER_HTML"))"
  print_kv "$(msg upload_html)" "$UPLOAD_HTML ($(path_state "$UPLOAD_HTML"), $(read_state "$UPLOAD_HTML"))"
  print_kv "$(msg cert_file)" "$CERT_FILE ($(path_state "$CERT_FILE"), $(read_state "$CERT_FILE"))"
  print_kv "$(msg key_file)" "$KEY_FILE ($(path_state "$KEY_FILE"), $(read_state "$KEY_FILE"))"
  print_kv "$(msg access_log)" "$ACCESS_LOG ($(path_state "$ACCESS_LOG"))"
  print_kv "$(msg error_log)" "$ERROR_LOG ($(path_state "$ERROR_LOG"))"
  print_kv "$(msg auth_user)" "${auth_user_name:-$(msg none)}"
  print_kv "$(msg free_space)" "$(free_space "$DATA_DIR")"
}

do_update() {
  local action="${1:-}"
  local project_dir install_script

  project_dir="${TFW_PROJECT_DIR:-}"
  if [[ -z "$project_dir" ]]; then
    echo "TFW_PROJECT_DIR not set." >&2
    echo "Run tfw update from within the project directory, or set TFW_PROJECT_DIR in /etc/tfw/tfw.conf." >&2
    exit 1
  fi

  if [[ ! -d "$project_dir" ]]; then
    echo "Project directory not found: $project_dir" >&2
    exit 1
  fi

  install_script="$project_dir/scripts/install.sh"
  if [[ ! -f "$install_script" ]]; then
    echo "install.sh not found in project directory: $install_script" >&2
    exit 1
  fi

  case "$action" in
    --check)
      if ! command -v git >/dev/null 2>&1; then
        echo "git not found; cannot check for updates." >&2
        exit 1
      fi
      if [[ ! -d "$project_dir/.git" ]]; then
        echo "$project_dir is not a git repository." >&2
        exit 1
      fi
      echo "Fetching from origin..."
      git -C "$project_dir" fetch origin 2>/dev/null || { echo "Fetch failed." >&2; exit 1; }
      local behind
      behind="$(git -C "$project_dir" rev-list HEAD..origin/main --count 2>/dev/null || echo "?")"
      if [[ "$behind" == "0" ]]; then
        echo "Already up to date."
        exit 0
      fi
      echo "$behind commit(s) behind origin/main."
      echo "Run 'tfw update --pull' to apply updates."
      ;;
    --pull)
      if ! command -v git >/dev/null 2>&1; then
        echo "git not found; cannot pull updates." >&2
        exit 1
      fi
      if [[ ! -d "$project_dir/.git" ]]; then
        echo "$project_dir is not a git repository." >&2
        exit 1
      fi
      if [[ -n "$(git -C "$project_dir" status --porcelain 2>/dev/null)" ]]; then
        echo "WARNING: Local modifications detected. Pull may cause conflicts."
        echo "Continue? [y/N]"
        local answer
        read -r answer
        [[ "$answer" == "y" || "$answer" == "Y" ]] || { echo "Aborted."; exit 0; }
      fi
      echo "Pulling from origin/main..."
      git -C "$project_dir" pull origin main || { echo "Pull failed." >&2; exit 1; }
      echo "Pull complete. Running upgrade..."
      need_root
      LANGUAGE="${LANGUAGE:-en}" bash "$install_script" upgrade
      echo "Update complete."
      ;;
    "")
      need_root
      echo "Running upgrade from $project_dir..."
      LANGUAGE="${LANGUAGE:-en}" bash "$install_script" upgrade
      ;;
    *)
      echo "Usage: tfw update [--check|--pull]" >&2
      exit 1
      ;;
  esac
}

do_uninstall() {
  local keep_data=1 keep_certs=1 install_script project_dir answer

  project_dir="${TFW_PROJECT_DIR:-}"
  if [[ -z "$project_dir" || ! -d "$project_dir" ]]; then
    echo "$(msg missing_runtime)" >&2
    exit 1
  fi

  install_script="$project_dir/scripts/install.sh"
  if [[ ! -f "$install_script" ]]; then
    echo "$(msg uninstall_no_project): $install_script" >&2
    exit 1
  fi

  echo "$(msg uninstall_title)"
  printf '%-15s: %s\n' "$(msg uninstall_data_dir)" "${DATA_DIR:-/srv/tfw/data}"
  printf '%-15s: %s\n' "$(msg uninstall_certs_dir)" "${SITE_DIR:-/etc/tfw/sites}/${SITE_ID:-site}/certs"
  echo ""
  read -r -p "$(msg uninstall_confirm): " answer
  [[ "$answer" == "y" || "$answer" == "Y" ]] || { echo "$(msg uninstall_aborted)"; exit 0; }

  read -r -p "$(msg uninstall_keep_data): " answer
  if [[ "$answer" == "n" || "$answer" == "N" ]]; then keep_data=0; fi

  read -r -p "$(msg uninstall_keep_certs): " answer
  if [[ "$answer" == "n" || "$answer" == "N" ]]; then keep_certs=0; fi

  need_root
  UNINSTALL_KEEP_DATA="$keep_data" UNINSTALL_KEEP_CERTS="$keep_certs" LANGUAGE="${LANGUAGE:-en}" bash "$install_script" uninstall
}

usage() {
  local help_text
  help_text="$(cat <<'EOF'
tfw time                         __HELP_TIME__
tfw info                         __HELP_INFO__
tfw urls                         __HELP_URLS__
tfw cert                         __HELP_CERT__
tfw status                       __HELP_STATUS__
tfw auth [user] [password]       __HELP_AUTH__
tfw config                       __HELP_CONFIG_CMD__
tfw doctor                       __HELP_DOCTOR__
tfw test                         __HELP_TEST__
tfw ls [root|uploads|/path]      __HELP_LS__
tfw logs [access|error|all] [lines]  __HELP_LOGS__
tfw restart                      __HELP_RESTART__
tfw passwd [user] [password]     __HELP_PASSWD__

	tfw session [rotate|show]          __HELP_SESSION__
	tfw update [--check|--pull]        __HELP_UPDATE__
	tfw uninstall                       __HELP_UNINSTALL__
__HELP_CONFIG__:
  __HELP_DEFAULT_CONFIG__: /etc/tfw/tfw.conf
  __HELP_OVERRIDE__: TFW_CONFIG=/path/to/tfw.conf tfw info
EOF
)"
  printf '%s\n' "$help_text" | sed \
    -e "s|__HELP_TIME__|$(msg help_time)|g" \
    -e "s|__HELP_INFO__|$(msg help_info)|g" \
    -e "s|__HELP_URLS__|$(msg help_urls)|g" \
    -e "s|__HELP_CERT__|$(msg help_cert)|g" \
    -e "s|__HELP_STATUS__|$(msg help_status)|g" \
    -e "s|__HELP_AUTH__|$(msg help_auth)|g" \
    -e "s|__HELP_CONFIG_CMD__|$(msg help_config_cmd)|g" \
    -e "s|__HELP_DOCTOR__|$(msg help_doctor)|g" \
    -e "s|__HELP_TEST__|$(msg help_test)|g" \
    -e "s|__HELP_LS__|$(msg help_ls)|g" \
    -e "s|__HELP_LOGS__|$(msg help_logs)|g" \
    -e "s|__HELP_RESTART__|$(msg help_restart)|g" \
    -e "s|__HELP_PASSWD__|$(msg help_passwd)|g" \
    -e "s|__HELP_SESSION__|$(msg help_session)|g" \
    -e "s|__HELP_UPDATE__|$(msg help_update)|g" \
    -e "s|__HELP_UNINSTALL__|$(msg help_uninstall)|g" \
    -e "s|__HELP_CONFIG__|$(msg help_config)|g" \
    -e "s|__HELP_DEFAULT_CONFIG__|$(msg help_default_config)|g" \
    -e "s|__HELP_OVERRIDE__|$(msg help_override)|g"
}

case "${1:-}" in
  time)
    show_time
    ;;
  info)
    show_info
    ;;
  urls|url)
    show_urls
    ;;
  cert|certs)
    show_cert
    ;;
  status|health)
    show_status
    ;;
  auth)
    shift
    show_auth "$@"
    ;;
  config|conf)
    show_config
    ;;
  doctor|check)
    show_doctor
    ;;
  test|nginx-test)
    test_nginx
    ;;
  ls|list)
    shift
    list_dir "${1:-root}"
    ;;
  logs|log)
    shift
    show_logs "${1:-access}" "${2:-50}"
    ;;
  restart)
    restart_nginx
    ;;
  passwd)
    shift
    rotate_passwd "$@"
    ;;
  session)
    shift
    case "${1:-}" in
      rotate|renew)
        need_root
        need openssl
        new_token="$(openssl rand -hex 24)"
        if [[ -f "$CONFIG_FILE" ]]; then
          sed -i "s/^AUTH_SESSION_TOKEN=.*/AUTH_SESSION_TOKEN='$new_token'/" "$CONFIG_FILE"
        fi
        AUTH_MAP_FILE="${AUTH_MAP_FILE:-/etc/nginx/conf.d/temp-file-web-map.conf}"
        if [[ -f "$AUTH_MAP_FILE" ]]; then
          sed -i "s/\"[^\"]*\"/\"$new_token\"/" "$AUTH_MAP_FILE"
        fi
        if [[ -f "$CONF" ]]; then
          sed -i "/Set-Cookie.*tfw_upload_auth=/s/tfw_upload_auth=[^;]*/tfw_upload_auth=$new_token/" "$CONF"
        fi
        nginx -t && (systemctl reload nginx 2>/dev/null || nginx -s reload 2>/dev/null || true)
        AUTH_SESSION_TOKEN="$new_token"
        echo "Session token rotated."
        echo "New token: $new_token"
        ;;
      show|status)
        [[ -n "${AUTH_SESSION_TOKEN:-}" ]] && echo "AUTH_SESSION_TOKEN=${AUTH_SESSION_TOKEN}" || echo "AUTH_SESSION_TOKEN not set"
        ;;
      *)
        echo "Usage: tfw session [rotate|show]" >&2
        exit 1
        ;;
    esac
    ;;
  update|upgrade)
    shift
    do_update "$@"
    ;;
  uninstall)
    do_uninstall
    ;;
  ""|help|-h|--help)
    usage
    ;;
  *)
    echo "$(msg unknown_command "$1")" >&2
    usage
    exit 1
    ;;
esac
