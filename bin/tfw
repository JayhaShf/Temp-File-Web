#!/usr/bin/env bash

set -euo pipefail

CONFIG_FILE="${TFW_CONFIG:-/etc/tfw/tfw.conf}"

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

DOMAIN="${DOMAIN:-}"
SITE_ID="${SITE_ID:-site}"
IP="${IP:-127.0.0.1}"
ACCESS_HOST="${ACCESS_HOST:-${DOMAIN:-$IP}}"
SITE_TITLE="${SITE_TITLE:-Temp File Web}"
LANGUAGE="${LANGUAGE:-en}"
INSTALL_ACME="${INSTALL_ACME:-1}"
SITE_MODE="${SITE_MODE:-https}"
HTTP_PORT="${HTTP_PORT:-80}"
HTTPS_PORT="${HTTPS_PORT:-443}"
CONF="${CONF:-/etc/nginx/conf.d/tfw-$SITE_ID.conf}"
SITE_DIR="${SITE_DIR:-/etc/tfw/sites/$SITE_ID}"
AUTH_FILE="${AUTH_FILE:-$SITE_DIR/file-upload.htpasswd}"
DATA_DIR="${DATA_DIR:-/srv/tfw/data}"
UPLOAD_DIR="${UPLOAD_DIR:-$DATA_DIR/uploads}"
BROWSER_HTML="${BROWSER_HTML:-$SITE_DIR/file-browser.html}"
UPLOAD_HTML="${UPLOAD_HTML:-$SITE_DIR/file-upload.html}"
ACCESS_LOG="${ACCESS_LOG:-/var/log/nginx/$SITE_ID.access.log}"
ERROR_LOG="${ERROR_LOG:-/var/log/nginx/$SITE_ID.error.log}"
ACME_WEBROOT="${ACME_WEBROOT:-/var/www/_acme-challenge}"
CERT_FILE="${CERT_FILE:-$SITE_DIR/certs/fullchain.cer}"
KEY_FILE="${KEY_FILE:-$SITE_DIR/certs/$SITE_ID.key}"
MAX_UPLOAD_SIZE="${MAX_UPLOAD_SIZE:-2g}"
ACME_HOME="${ACME_HOME:-/root/.acme.sh}"
ACME_BIN="${ACME_BIN:-$ACME_HOME/acme.sh}"
TFW_USER="${TFW_USER:-www-data}"

url_scheme="https"
url_port="$HTTPS_PORT"
if [[ "$SITE_MODE" == "http" ]]; then
  url_scheme="http"
  url_port="$HTTP_PORT"
fi

url_authority="$ACCESS_HOST"
default_port="$HTTPS_PORT"
if [[ "$SITE_MODE" == "http" ]]; then
  default_port="$HTTP_PORT"
fi

if [[ "$url_port" != "$default_port" ]]; then
  url_authority="${ACCESS_HOST}:${url_port}"
elif [[ "$SITE_MODE" == "http" && "$HTTP_PORT" != "80" ]]; then
  url_authority="${ACCESS_HOST}:${HTTP_PORT}"
elif [[ "$SITE_MODE" == "https" && "$HTTPS_PORT" != "443" ]]; then
  url_authority="${ACCESS_HOST}:${HTTPS_PORT}"
fi

url_root="${url_scheme}://${url_authority}/"
url_upload="${url_scheme}://${url_authority}/upload"
url_uploads="${url_scheme}://${url_authority}/uploads/"
url_listing="${url_scheme}://${url_authority}/_listing/"

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing command: $1" >&2
    exit 1
  }
}

need_root() {
  [[ "$(id -u)" -eq 0 ]] || {
    echo "need root" >&2
    exit 1
  }
}

auth_user() {
  if [[ -f "$AUTH_FILE" ]]; then
    awk -F: 'NR==1{print $1; exit}' "$AUTH_FILE"
  fi
}

set_auth_file_permissions() {
  local owner_group

  chmod 0640 "$AUTH_FILE"
  if id -u "$TFW_USER" >/dev/null 2>&1; then
    owner_group="$(id -gn "$TFW_USER")"
    chown root:"$owner_group" "$AUTH_FILE"
  else
    chown root:root "$AUTH_FILE"
  fi
}

path_state() {
  local path="$1"
  if [[ -d "$path" ]]; then
    echo "ok (dir)"
  elif [[ -f "$path" ]]; then
    echo "ok (file)"
  else
    echo "missing"
  fi
}

count_entries() {
  local dir="$1"
  local kind="${2:-all}"

  if [[ ! -d "$dir" ]]; then
    echo 0
    return 0
  fi

  if [[ "$kind" == "files" ]]; then
    find "$dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | awk '{print $1}'
  else
    find "$dir" -mindepth 1 -maxdepth 1 2>/dev/null | wc -l | awk '{print $1}'
  fi
}

dir_size() {
  local dir="$1"

  if [[ -d "$dir" ]]; then
    du -sh "$dir" 2>/dev/null | awk '{print $1}'
  else
    echo 0
  fi
}

free_space() {
  local path="$1"
  local value

  if [[ -e "$path" || -d "$(dirname "$path")" ]]; then
    value="$(df -h "$path" 2>/dev/null | awk 'NR==2{print $4}')"
  fi

  echo "${value:--}"
}

resolve_dir() {
  case "${1:-root}" in
    ""|root)
      printf '%s\n' "$DATA_DIR"
      ;;
    upload|uploads)
      printf '%s\n' "$UPLOAD_DIR"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

http_code() {
  local url="$1"
  local auth="${2:-}"
  if [[ -n "$auth" ]]; then
    curl -sk -o /dev/null -w '%{http_code}' --resolve "${ACCESS_HOST}:${url_port}:${IP}" -u "$auth" "$url" 2>/dev/null || echo ERR
  else
    curl -sk -o /dev/null -w '%{http_code}' --resolve "${ACCESS_HOST}:${url_port}:${IP}" "$url" 2>/dev/null || echo ERR
  fi
}

show_time() {
  echo "local : $(date '+%Y-%m-%d %H:%M:%S %Z (%z)')"
  echo "utc   : $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
  echo "host  : $(hostname)"
}

show_urls() {
  echo "root            : $url_root"
  echo "upload page     : $url_upload"
  echo "uploads dir     : $url_uploads"
  echo "listing api     : $url_listing"
}

show_info() {
  echo "runtime config  : $CONFIG_FILE ($(path_state "$CONFIG_FILE"))"
  echo "language        : $LANGUAGE"
  echo "site mode       : $SITE_MODE"
  echo "site title      : $SITE_TITLE"
  echo "site id         : $SITE_ID"
  if [[ -n "$DOMAIN" ]]; then
    echo "domain          : $DOMAIN"
  fi
  echo "access host     : $ACCESS_HOST"
  echo "http port       : $HTTP_PORT"
  echo "https port      : $HTTPS_PORT"
  echo "resolve ip      : $IP"
  echo "site dir        : $SITE_DIR ($(path_state "$SITE_DIR"))"
  echo "config file     : $CONF ($(path_state "$CONF"))"
  echo "auth file       : $AUTH_FILE ($(path_state "$AUTH_FILE"))"
  echo "data dir        : $DATA_DIR ($(path_state "$DATA_DIR"))"
  echo "upload dir      : $UPLOAD_DIR ($(path_state "$UPLOAD_DIR"))"
  echo "browser html    : $BROWSER_HTML ($(path_state "$BROWSER_HTML"))"
  echo "upload html     : $UPLOAD_HTML ($(path_state "$UPLOAD_HTML"))"
  echo "acme enabled    : $INSTALL_ACME"
  if [[ "$INSTALL_ACME" == "1" ]]; then
    echo "acme webroot    : $ACME_WEBROOT ($(path_state "$ACME_WEBROOT"))"
  fi
  echo "cert file       : $CERT_FILE ($(path_state "$CERT_FILE"))"
  echo "key file        : $KEY_FILE ($(path_state "$KEY_FILE"))"
  echo "access log      : $ACCESS_LOG ($(path_state "$ACCESS_LOG"))"
  echo "error log       : $ERROR_LOG ($(path_state "$ERROR_LOG"))"
  echo "auth user       : $(auth_user || true)"
  echo
  show_urls
}

test_nginx() {
  need nginx
  nginx -t
}

show_status() {
  need nginx
  need curl

  local listing_payload listing_count auth_user_name
  listing_payload="$(curl -sk --resolve "${ACCESS_HOST}:${url_port}:${IP}" "$url_listing" 2>/dev/null || true)"
  listing_count="$(printf '%s' "$listing_payload" | grep -o '"name":"' | wc -l | awk '{print $1}')"
  auth_user_name="$(auth_user || true)"

  echo "time            : $(date '+%Y-%m-%d %H:%M:%S %Z (%z)')"
  echo "site mode       : $SITE_MODE"
  if [[ -n "$DOMAIN" ]]; then
    echo "domain          : $DOMAIN"
  fi
  echo "access host     : $ACCESS_HOST"
  echo "resolve ip      : $IP"
  echo "config file     : $CONF ($(path_state "$CONF"))"
  echo "auth file       : $AUTH_FILE ($(path_state "$AUTH_FILE"))"
  echo "cert file       : $CERT_FILE ($(path_state "$CERT_FILE"))"
  echo "key file        : $KEY_FILE ($(path_state "$KEY_FILE"))"
  echo "data dir        : $DATA_DIR ($(path_state "$DATA_DIR"))"
  echo "upload dir      : $UPLOAD_DIR ($(path_state "$UPLOAD_DIR"))"
  echo "free space      : $(free_space "$DATA_DIR")"
  nginx -t >/dev/null 2>&1 && echo "nginx test      : ok" || echo "nginx test      : fail"
  pgrep -x nginx >/dev/null 2>&1 && echo "nginx process   : ok ($(pgrep -xc nginx))" || echo "nginx process   : fail"
  echo "auth user       : ${auth_user_name:-none}"
  echo "root items      : $(count_entries "$DATA_DIR")"
  echo "upload files    : $(count_entries "$UPLOAD_DIR" files)"
  echo "upload size     : $(dir_size "$UPLOAD_DIR")"
  echo "root page       : $(http_code "$url_root")"
  echo "uploads page    : $(http_code "$url_uploads")"
  echo "listing json    : $(http_code "$url_listing")"
  echo "upload page     : $(http_code "$url_upload") (expect 401)"
  echo "listing count   : ${listing_count:-0}"
}

list_dir() {
  local target="${1:-root}"
  local dir

  dir="$(resolve_dir "$target")"
  if [[ ! -d "$dir" ]]; then
    echo "directory not found: $dir" >&2
    exit 1
  fi

  echo "directory       : $dir"
  ls -lah "$dir"
}

show_logs() {
  local target="${1:-access}"
  local lines="${2:-50}"
  local file

  case "$target" in
    access)
      file="$ACCESS_LOG"
      ;;
    error)
      file="$ERROR_LOG"
      ;;
    *)
      echo "unknown log target: $target" >&2
      echo "use: tfw logs [access|error] [lines]" >&2
      exit 1
      ;;
  esac

  [[ "$lines" =~ ^[0-9]+$ ]] || {
    echo "lines must be an integer" >&2
    exit 1
  }

  [[ -f "$file" ]] || {
    echo "log not found: $file" >&2
    exit 1
  }

  echo "log file        : $file"
  echo "lines           : $lines"
  tail -n "$lines" "$file"
}

restart_nginx() {
  need_root
  need nginx

  nginx -t
  if command -v systemctl >/dev/null 2>&1; then
    if systemctl restart nginx; then
      echo "restart         : systemctl ok"
    else
      nginx -s reload
      echo "restart         : reload ok"
    fi
  else
    nginx -s reload
    echo "restart         : reload ok"
  fi
  sleep 1
  show_status
}

rotate_passwd() {
  need_root
  need openssl

  local user input_user password password2 backup hash code current_user
  [[ $# -le 2 ]] || {
    echo "use: tfw passwd [user] [password]" >&2
    exit 1
  }

  current_user="$(auth_user || true)"
  user="${1:-$current_user}"
  user="${user:-uploader}"
  password="${2:-}"

  if [[ -t 0 ]]; then
    if [[ $# -eq 0 ]]; then
      read -r -p "user [${user}]: " input_user
      user="${input_user:-$user}"
    fi

    if [[ $# -lt 2 ]]; then
      read -r -s -p "new password (empty = random): " password
      printf '\n'
      if [[ -n "${password:-}" ]]; then
        read -r -s -p "confirm: " password2
        printf '\n'
        [[ "$password" == "$password2" ]] || {
          echo "password mismatch" >&2
          exit 1
        }
      fi
    fi
  fi

  if [[ -z "${password:-}" ]]; then
    password="$(openssl rand -base64 18 | tr -d '=+/\n' | cut -c1-20)"
  fi

  backup=""
  if [[ -f "$AUTH_FILE" ]]; then
    backup="${AUTH_FILE}.bak-$(date +%Y%m%d%H%M%S)"
    cp "$AUTH_FILE" "$backup"
  else
    mkdir -p "$(dirname "$AUTH_FILE")"
  fi

  hash="$(openssl passwd -apr1 "$password")"
  umask 077
  printf '%s:%s\n' "$user" "$hash" > "$AUTH_FILE"
  set_auth_file_permissions

  if ! awk -F: 'NR==1 && NF>=2 && $1 != "" {ok=1} END {exit ok ? 0 : 1}' "$AUTH_FILE"; then
    if [[ -n "$backup" ]]; then
      cp "$backup" "$AUTH_FILE"
    else
      rm -f "$AUTH_FILE"
    fi
    echo "password verify failed: auth file format invalid, rolled back" >&2
    exit 1
  fi

  code="$(http_code "$url_upload" "${user}:${password}")"

  echo "user            : $user"
  echo "password        : $password"
  echo "backup          : ${backup:-not created}"
  echo "local verify    : ok"
  echo "remote verify   : $code"
}

show_cert() {
  echo "site mode       : $SITE_MODE"
  echo "acme enabled    : $INSTALL_ACME"
  if [[ "$INSTALL_ACME" == "1" ]]; then
    echo "acme bin        : $ACME_BIN ($(path_state "$ACME_BIN"))"
    echo "acme home       : $ACME_HOME ($(path_state "$ACME_HOME"))"
  fi
  echo "cert file       : $CERT_FILE ($(path_state "$CERT_FILE"))"
  echo "key file        : $KEY_FILE ($(path_state "$KEY_FILE"))"
}

usage() {
  cat <<'EOF'
tfw time                         show host time
tfw info                         show config paths and local files
tfw urls                         show public URLs
tfw cert                         show certificate paths
tfw status                       run nginx and HTTP checks
tfw test                         run nginx -t
tfw ls [root|uploads|/path]      list files in a directory
tfw logs [access|error] [lines]  tail nginx logs
tfw restart                      test and restart/reload nginx
tfw passwd [user] [password]     rotate upload auth password

Config source:
  default runtime config: /etc/tfw/tfw.conf
  override with: TFW_CONFIG=/path/to/tfw.conf tfw info
EOF
}

case "${1:-}" in
  time)
    show_time
    ;;
  info)
    show_info
    ;;
  urls|url)
    show_urls
    ;;
  cert|certs)
    show_cert
    ;;
  status)
    show_status
    ;;
  test|nginx-test)
    test_nginx
    ;;
  ls|list)
    shift
    list_dir "${1:-root}"
    ;;
  logs|log)
    shift
    show_logs "${1:-access}" "${2:-50}"
    ;;
  restart)
    restart_nginx
    ;;
  passwd)
    shift
    rotate_passwd "$@"
    ;;
  ""|help|-h|--help)
    usage
    ;;
  *)
    echo "unknown command: $1" >&2
    usage
    exit 1
    ;;
esac
